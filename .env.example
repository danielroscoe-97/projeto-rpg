# Update these with your Supabase details from your project settings > API
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# Google Gemini API key for Oracle AI (free tier: https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key

# Supabase service role key (server-only, bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Upstash Redis (rate limiting — fail-open if not set)
# Create a Redis database at https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Stripe (Epic 5 — monetization)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_YEARLY=price_...

# Resend (campaign invite emails — get key from https://resend.com/api-keys)
RESEND_API_KEY=re_...
# Optional: override sender email (default: Pocket DM <noreply@pocketdm.com.br>)
# RESEND_FROM_EMAIL=Pocket DM <noreply@pocketdm.com.br>

# Sentry error tracking (free tier: 5K errors/month)
# Get DSN from https://sentry.io → Project Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@o123456.ingest.sentry.io/789
SENTRY_DSN=https://your-dsn@o123456.ingest.sentry.io/789

# Vercel Cron secret (auto-set by Vercel, add to env vars for local testing)
CRON_SECRET=your-cron-secret

# Site URL (used for metadataBase, canonical tags, sitemap, robots.ts, Stripe redirects, OG tags)
# MUST match the canonical domain configured on Vercel (currently apex, no www).
# Verify: `curl -I https://www.pocketdm.com.br` should return 301 → apex.
# If you change the canonical, update this env var in Vercel Production env too.
NEXT_PUBLIC_SITE_URL=https://pocketdm.com.br

# Web Push / VAPID keys for turn notifications (Story 1.5)
# Generate a new keypair: node -e "const w=require('web-push');const k=w.generateVAPIDKeys();console.log(k)"
# NEXT_PUBLIC_VAPID_PUBLIC_KEY is safe to expose — it's the public key
# VAPID_PRIVATE_KEY must stay server-side only
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:noreply@pocketdm.com.br

# ── E2E test mode (Playwright hooks) ──
# Gate for dev-only test surfaces:
#   - window.__pocketdm_supabase (browser client exposed for Playwright to drive
#     supabase.auth.updateUser directly — used by identity-upgrade specs)
#   - /api/e2e/seed-session-token, /api/e2e/auth-as-anon, /api/e2e/cleanup
#     (dev-only test API routes that return 404 unless this flag is EXACTLY "true")
#
# MUST be "false" (or unset) in production. Any other value is treated as off.
# Strict compare: the code uses `process.env.NEXT_PUBLIC_E2E_MODE === "true"` —
# truthy strings like "1" or "yes" WILL NOT enable the hooks.
#
# Playwright's webServer block in playwright.config.ts sets this to "true"
# automatically when running E2E locally.
NEXT_PUBLIC_E2E_MODE=false

# ── Grimório / Player HQ V2 redesign feature flag (see lib/flags/player-hq-v2.ts) ──
# Gates the 4-tab Player HQ redesign (Herói/Arsenal/Diário/Mapa) and all
# conversion/journey surfaces that will read it from Sprint 2 onward.
#
# Strict compare: ONLY the exact string "true" (lowercase) enables the flag.
# Any other value — "1", "yes", empty, unset, typo — resolves to OFF. This
# mirrors NEXT_PUBLIC_E2E_MODE and is intentional: a typo can never flip V2
# on in prod accidentally.
#
# Recommended Vercel settings:
#   Production:  NEXT_PUBLIC_PLAYER_HQ_V2=false   (until Sprint 10 flag flip)
#   Preview:     NEXT_PUBLIC_PLAYER_HQ_V2=true    (continuous V2 QA)
#   Staging:     NEXT_PUBLIC_PLAYER_HQ_V2=true    (continuous V2 QA)
#   Development: NEXT_PUBLIC_PLAYER_HQ_V2=true    (agent worktrees work on V2)
#
# Timeline: Sprint 10 deletes this flag + `lib/flags/player-hq-v2.ts` together.
# See docs/feature-flags.md and _bmad-output/party-mode-2026-04-22/14-sprint-plan.md §2.
NEXT_PUBLIC_PLAYER_HQ_V2=false

# ── Beta 3 remediation feature flags (see lib/flags.ts) ──
# Defaults to false. Flip to "1" (or "true") after the player-client soak
# window has elapsed — see docs/sprint-plan-beta3-remediation.md S1.2 rollout.
#
# ff_combatant_add_reorder: atomic combat:combatant_add_reorder broadcast
# replacing the legacy combatant_add + state_sync pair. Fixes the 3-rapid-adds
# turn-order race (Lucas / beta3 Finding 2).
NEXT_PUBLIC_FF_COMBATANT_ADD_REORDER=
# ff_hp_thresholds_v2: reserved for S3.1.
NEXT_PUBLIC_FF_HP_THRESHOLDS_V2=
# ff_custom_conditions_v1: reserved for S4.2.
NEXT_PUBLIC_FF_CUSTOM_CONDITIONS_V1=
