# Update these with your Supabase details from your project settings > API
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# Google Gemini API key for Oracle AI (free tier: https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key

# Supabase service role key (server-only, bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Upstash Redis (rate limiting — fail-open if not set)
# Create a Redis database at https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Stripe (Epic 5 — monetization)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_YEARLY=price_...

# Resend (campaign invite emails — get key from https://resend.com/api-keys)
RESEND_API_KEY=re_...
# Optional: override sender email (default: Pocket DM <noreply@pocketdm.com.br>)
# RESEND_FROM_EMAIL=Pocket DM <noreply@pocketdm.com.br>

# Sentry error tracking (free tier: 5K errors/month)
# Get DSN from https://sentry.io → Project Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@o123456.ingest.sentry.io/789
SENTRY_DSN=https://your-dsn@o123456.ingest.sentry.io/789

# Vercel Cron secret (auto-set by Vercel, add to env vars for local testing)
CRON_SECRET=your-cron-secret

# Site URL (used for metadataBase, canonical tags, sitemap, robots.ts, Stripe redirects, OG tags)
# MUST match the canonical domain configured on Vercel (currently apex, no www).
# Verify: `curl -I https://www.pocketdm.com.br` should return 301 → apex.
# If you change the canonical, update this env var in Vercel Production env too.
NEXT_PUBLIC_SITE_URL=https://pocketdm.com.br

# Web Push / VAPID keys for turn notifications (Story 1.5)
# Generate a new keypair: node -e "const w=require('web-push');const k=w.generateVAPIDKeys();console.log(k)"
# NEXT_PUBLIC_VAPID_PUBLIC_KEY is safe to expose — it's the public key
# VAPID_PRIVATE_KEY must stay server-side only
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:noreply@pocketdm.com.br
